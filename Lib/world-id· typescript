import { z } from 'zod'

export const worldIdProofSchema = z.object({
  merkle_root: z.string().min(1),
  nullifier_hash: z.string().min(1),
  proof: z.string().min(1),
  verification_level: z.string().optional(),
  action: z.string().min(1),
  signal: z.string().optional()
})

export type WorldIdProofPayload = z.infer<typeof worldIdProofSchema>

export async function verifyWorldIdProof(payload: WorldIdProofPayload) {
  const rpId = process.env.WORLD_RP_ID

  if (!rpId) {
    throw new Error('Missing WORLD_RP_ID environment variable')
  }

  const response = await fetch(`https://developer.world.org/api/v4/verify/${rpId}`, {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({
      merkle_root: payload.merkle_root,
      nullifier_hash: payload.nullifier_hash,
      proof: payload.proof,
      verification_level: payload.verification_level,
      action: payload.action,
      signal: payload.signal ?? ''
    })
  })

  const result = await response.json()

  if (!response.ok) {
    return {
      success: false,
      status: response.status,
      result
    }
  }

  return {
    success: true,
    status: response.status,
    result
  }
}

export function calculateInitialTrustScore(input: {
  worldVerified: boolean
  verificationLevel?: string
}) {
  let score = 0

  if (input.worldVerified) score += 70
  if (input.verificationLevel === 'orb') score += 20
  if (input.verificationLevel === 'device') score += 10

  return Math.min(score, 100)
}
